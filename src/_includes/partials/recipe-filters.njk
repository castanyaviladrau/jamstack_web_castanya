{% macro recipeFiltersBar(actionUrl, difficultyOptions, dishTypeOptions, searchLabel, showReset) %}
<form
  class="gastronomic-recipes-filters__inner"
  action="{{ actionUrl }}"
  method="get"
  data-recipe-filter-form
>
  <div
    class="gastronomic-recipes-filters__list"
    aria-label="Filtres de receptes"
  >
    <details class="shop-page-filter-menu" data-recipe-filter-menu="difficulty">
      <summary class="shop-page-filter" data-recipe-filter-summary data-default-label="Nivell de dificultat">
        <span data-recipe-filter-summary-label>Nivell de dificultat</span>
        <span aria-hidden="true">&#8964;</span>
      </summary>
      <div class="shop-page-filter-menu__list">
        {% for value in difficultyOptions %}
        <button
          type="button"
          class="shop-page-filter-menu__item"
          data-recipe-filter-option
          data-recipe-filter-value="{{ value }}"
          data-recipe-filter-label="{{ value | difficultyLabel }}"
        >{{ value | difficultyLabel }}</button>
        {% endfor %}
      </div>
      <input type="hidden" name="difficulty" data-recipe-filter-input value="" />
    </details>

    <details class="shop-page-filter-menu" data-recipe-filter-menu="time">
      <summary class="shop-page-filter" data-recipe-filter-summary data-default-label="Temps de preparacio">
        <span data-recipe-filter-summary-label>Temps de preparacio</span>
        <span aria-hidden="true">&#8964;</span>
      </summary>
      <div class="shop-page-filter-menu__list">
        <button type="button" class="shop-page-filter-menu__item" data-recipe-filter-option data-recipe-filter-value="short" data-recipe-filter-label="Menys de 20 minuts">Menys de 20 minuts</button>
        <button type="button" class="shop-page-filter-menu__item" data-recipe-filter-option data-recipe-filter-value="medium" data-recipe-filter-label="Entre 20 i 30 minuts">Entre 20 i 30 minuts</button>
        <button type="button" class="shop-page-filter-menu__item" data-recipe-filter-option data-recipe-filter-value="long" data-recipe-filter-label="Mes de 30 minuts">Mes de 30 minuts</button>
      </div>
      <input type="hidden" name="time" data-recipe-filter-input value="" />
    </details>

    <details class="shop-page-filter-menu" data-recipe-filter-menu="dishType">
      <summary class="shop-page-filter" data-recipe-filter-summary data-default-label="Tipus de plat">
        <span data-recipe-filter-summary-label>Tipus de plat</span>
        <span aria-hidden="true">&#8964;</span>
      </summary>
      <div class="shop-page-filter-menu__list">
        {% for value in dishTypeOptions %}
        <button
          type="button"
          class="shop-page-filter-menu__item"
          data-recipe-filter-option
          data-recipe-filter-value="{{ value }}"
          data-recipe-filter-label="{{ value | dishTypeLabel }}"
        >{{ value | dishTypeLabel }}</button>
        {% endfor %}
      </div>
      <input type="hidden" name="dishType" data-recipe-filter-input value="" />
    </details>
  </div>
  <div class="gastronomic-recipes-filters__actions">
    {% if showReset %}
    <button
      type="button"
      class="gastronomic-recipes-filters__reset"
      data-recipe-results-reset
      hidden
    >
      Esborra filtres
    </button>
    {% endif %}
    <button type="submit" class="gastronomic-recipes-filters__search">
      {{ searchLabel }}
    </button>
  </div>
</form>
{% endmacro %}
