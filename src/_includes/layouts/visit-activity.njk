<!DOCTYPE html>
<html lang="{{ site.language }}">

  {% include "head.html" %}

  <body class="internal page-visit-activity{% if name %} page-{{ name }}{% endif %}">
    {% include "header.html" %}
    <aside class="visit-reservation-banner" aria-label="Reserva la visita">
      <div class="visit-reservation-banner__inner">
        <p class="visit-reservation-banner__prompt">{{ reservationPrompt }}</p>
        <div class="visit-reservation-banner__actions">
          {% if whatsappLink %}
          <a
            href="{{ whatsappLink }}"
            target="_blank"
            rel="noopener noreferrer"
            class="visit-reservation-banner__icon visit-reservation-banner__icon--whatsapp"
            aria-label="WhatsApp"
          >
            <img src="/assets/images/whatsapp_button.png" alt="" aria-hidden="true" />
          </a>
          {% endif %}

          {% if emailAddress %}
          <a href="mailto:{{ emailAddress }}" class="visit-reservation-banner__icon" aria-label="Email">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="m4 7 8 6 8-6"></path>
            </svg>
          </a>
          {% endif %}

          {% if phoneNumber %}
          <a
            href="tel:{{ phoneNumber | replace(' ', '') }}"
            class="visit-reservation-banner__icon"
            aria-label="Telefon"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.1 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7l.5 3a2 2 0 0 1-.6 1.8L7.6 9.8a16 16 0 0 0 6.6 6.6l1.3-1.3a2 2 0 0 1 1.8-.6l3 .5A2 2 0 0 1 22 16.9Z"
              ></path>
            </svg>
          </a>
          {% endif %}
        </div>
      </div>
    </aside>
    <div class="outer-wrap">
      <div class="content-wrap">
        <section class="visit-activity-hero hero-wrapper">
          <img
            src="{{ heroImage }}"
            alt="{{ heroImageAlt }}"
            class="hero-img visit-activity-hero__image"
          />

          <div class="hero-content-overlay visit-activity-hero__overlay">
            <div class="visit-activity-hero__content">
              <a href="/visits/" class="visit-activity-hero__back">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M19 12H5m6-6-6 6 6 6" />
                </svg>
                <span>Tornar</span>
              </a>
              <h1 class="visit-activity-hero__title">{{ title }}</h1>

              <div class="visit-activity-hero__actions">
                <p class="visit-activity-hero__reservation">{{ reservationPrompt }}</p>

                {% if whatsappLink %}
                <a
                  href="{{ whatsappLink }}"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="visit-activity-hero__icon visit-activity-hero__icon--whatsapp"
                  aria-label="WhatsApp"
                >
                  <img
                    src="/assets/images/whatsapp_button.png"
                    alt=""
                    class="visit-activity-hero__whatsapp-image"
                    aria-hidden="true"
                  />
                </a>
                {% endif %}

                {% if emailAddress %}
                <a
                  href="mailto:{{ emailAddress }}"
                  class="visit-activity-hero__icon"
                  aria-label="Email"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                    <path d="m4 7 8 6 8-6"></path>
                  </svg>
                </a>
                {% endif %}

                {% if phoneNumber %}
                <a
                  href="tel:{{ phoneNumber | replace(' ', '') }}"
                  class="visit-activity-hero__icon"
                  aria-label="Telefon"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.1 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7l.5 3a2 2 0 0 1-.6 1.8L7.6 9.8a16 16 0 0 0 6.6 6.6l1.3-1.3a2 2 0 0 1 1.8-.6l3 .5A2 2 0 0 1 22 16.9Z"
                    ></path>
                  </svg>
                </a>
                {% endif %}

                <button
                  type="button"
                  class="visit-activity-hero__booking-button"
                  data-booking-trigger
                  aria-haspopup="dialog"
                  aria-controls="visitBookingModal"
                >
                  RESERVA
                </button>
              </div>
            </div>

            <div class="visit-activity-hero__reserve-bar" aria-label="Condicions de reserva">
              <p class="visit-activity-hero__reserve-row">
                <span class="visit-activity-hero__reserve-label">RESERVA ARA I PAGA DESPRÉS</span>
                <span class="visit-activity-hero__reserve-text">Reserva plaça mantenint la flexibilitat</span>
              </p>
              <p class="visit-activity-hero__reserve-row">
                <span class="visit-activity-hero__reserve-label">POLÍTICA DE CANCEL·LACIÓ FLEXIBLE</span>
                <span class="visit-activity-hero__reserve-text">Fins a 48 hores abans de la visita</span>
              </p>
            </div>
          </div>
        </section>

        <section class="visit-activity-facts unified-bg">
          <div class="visit-activity-facts__inner">
            <div class="visit-activity-facts__item">
              <img
                src="/assets/images/gallery/visites/visites_people.png"
                alt=""
                class="visit-activity-facts__icon"
              />
              <div>
                <strong>De {{ personsMin }} a {{ personsMax }} persones</strong>
              </div>
            </div>
            <div class="visit-activity-facts__item">
              <img
                src="/assets/images/gallery/visites/visites_clock.png"
                alt=""
                class="visit-activity-facts__icon"
              />
              <div>
                <strong>{{ duration }}</strong>
              </div>
            </div>
            <div class="visit-activity-facts__item">
              <img
                src="/assets/images/gallery/visites/visites_money.png"
                alt=""
                class="visit-activity-facts__icon"
              />
              <div>
                <strong>A partir de {{ priceFrom }}</strong>
                <small>{{ priceNote }}</small>
              </div>
            </div>
            <div class="visit-activity-facts__item">
              <img
                src="/assets/images/gallery/visites/visites_walker.png"
                alt=""
                class="visit-activity-facts__icon"
              />
              <div>
                <strong>{{ difficulty }}</strong>
              </div>
            </div>
            <div class="visit-activity-facts__item">
              <img
                src="/assets/images/gallery/visites/visites_children.png"
                alt=""
                class="visit-activity-facts__icon"
              />
              <div>
                <strong>{{ kidFriendly }}</strong>
              </div>
            </div>
            <div class="visit-activity-facts__item">
              <img
                src="/assets/images/gallery/visites/visites_global.png"
                alt=""
                class="visit-activity-facts__icon"
              />
              <div>
                <strong>{{ languages }}</strong>
              </div>
            </div>
          </div>
        </section>

        <section class="visit-activity-body unified-bg">
          <div class="visit-activity-body__inner">
            <div class="visit-activity-body__main">
              <details class="visit-activity-accordion" open>
                <summary class="block_heavy_content_style">DESCRIPCIO GENERAL</summary>
                <div class="visit-activity-accordion__content block_heavy_content_style">
                  {% if overviewIntro %}
                  <p class="visit-activity-body__intro">{{ overviewIntro }}</p>
                  {% endif %}
                  <div class="visit-activity-body__copy prose">{{ content | safe }}</div>
                </div>
              </details>

              <details class="visit-activity-accordion">
                <summary class="block_heavy_content_style">SERVEIS INCLOSOS</summary>
                <div class="visit-activity-accordion__content prose block_heavy_content_style">
                  {{ includedServices | markdownify | safe }}
                </div>
              </details>

              <details class="visit-activity-accordion">
                <summary class="block_heavy_content_style">TROBADA I PUNT DE RECOLLIDA</summary>
                <div class="visit-activity-accordion__content prose block_heavy_content_style">
                  {{ meetingPoint | markdownify | safe }}
                </div>
              </details>

              <details class="visit-activity-accordion">
                <summary class="block_heavy_content_style">INFORMACIO ADDICIONAL</summary>
                <div class="visit-activity-accordion__content prose block_heavy_content_style">
                  {{ additionalInfo | markdownify | safe }}
                </div>
              </details>

            </div>

            <aside class="visit-activity-sidebar">
              <section class="visit-activity-sidebar__section">
                <h2 class="visit-activity-sidebar__title block_title_style">ITINERARI</h2>
                <div class="visit-activity-timeline">
                  {% for item in itinerary %}
                  <div class="visit-activity-timeline__item">
                    <div class="visit-activity-timeline__time">{{ item.time }}</div>
                    <div class="visit-activity-timeline__text block_heavy_content_style">
                      <strong>{{ item.title }}</strong>
                      <p>{{ item.description }}</p>
                    </div>
                  </div>
                  {% endfor %}
                </div>
              </section>

              <section class="visit-activity-sidebar__section">
                <h2 class="visit-activity-sidebar__title block_title_style">PREUS X PERSONA</h2>
                <div class="visit-activity-pricing">
                  {% for item in pricing %}
                  <div class="visit-activity-pricing__row">
                    <span class="block_heavy_content_style">{{ item.group }} persones</span>
                    <strong class="block_title_style">{{ item.price }}</strong>
                  </div>
                  {% endfor %}
                </div>
              </section>
            </aside>
          </div>
        </section>

        <div class="visit-booking-modal" id="visitBookingModal" data-booking-modal hidden>
          <div class="visit-booking-modal__backdrop" data-booking-close="backdrop"></div>
          <div
            class="visit-booking-modal__dialog"
            role="dialog"
            aria-modal="true"
            aria-labelledby="visitBookingModalTitle"
          >
            <button
              type="button"
              class="visit-booking-modal__close"
              data-booking-close="button"
              aria-label="Tancar formulari"
            >
              <span aria-hidden="true">&times;</span>
            </button>

            <div class="visit-booking-modal__header">
              <p class="visit-booking-cta__eyebrow">RESERVA ARA</p>
              <h2 id="visitBookingModalTitle" class="visit-booking-cta__title">
                Sol.licita aquesta activitat
              </h2>
              <p class="visit-booking-modal__text">
                Ens has seleccionat <strong>{{ title }}</strong>. Completa el formulari i t'enviarem una confirmacio al teu correu.
              </p>
            </div>

            <form class="contact-form visit-booking-modal__form" data-booking-form>
              <input type="hidden" name="activityTitle" value="{{ title }}" />
              <input type="hidden" name="activityUrl" value="{{ (page.url | absoluteUrl(site.url)) }}" />

              <div class="contact-form__grid visit-booking-modal__grid">
                <label class="contact-form__field">
                  <span>Nom i cognoms</span>
                  <input type="text" name="name" autocomplete="name" placeholder="Nom i cognoms" required />
                </label>

                <label class="contact-form__field">
                  <span>Correu electronic</span>
                  <input type="email" name="email" autocomplete="email" placeholder="correu@exemple.cat" required />
                </label>

                <label class="contact-form__field">
                  <span>Telefon</span>
                  <input type="tel" name="phone" autocomplete="tel" placeholder="600 123 456" />
                </label>

                <label class="contact-form__field">
                  <span>Data preferida</span>
                  <input type="text" name="preferredDate" placeholder="Per exemple, 14 de novembre" required />
                </label>

                <label class="contact-form__field">
                  <span>Nombre de persones</span>
                  <input type="number" name="partySize" min="1" step="1" placeholder="4" required />
                </label>

                <label class="contact-form__field">
                  <span>Activitat</span>
                  <input type="text" value="{{ title }}" readonly />
                </label>
              </div>

              <label class="contact-form__field contact-form__field--full">
                <span>Comentaris</span>
                <textarea name="message" rows="5" placeholder="Explica'ns si prefereixes un horari concret o si hi ha alguna necessitat especial."></textarea>
              </label>

              <div class="contact-form__actions contact-form__actions--stacked visit-booking-modal__actions">
                <button type="submit" class="btn-olive contact-form__submit">ENVIAR SOL.LICITUD</button>
                <p class="visit-booking-modal__note">Et respondrem amb disponibilitat i detalls de reserva.</p>
                <p class="contact-form__status" data-booking-status aria-live="polite"></p>
              </div>
            </form>
          </div>
        </div>

        {% if experienceHighlightsSection and experienceHighlightsSection.items and experienceHighlightsSection.items.length %}
        <section class="visit-activity-experience">
          <div class="visit-activity-experience__inner">
            <div class="visit-activity-experience__header">
              <h2 class="visit-activity-experience__title block_title_style">{{ experienceHighlightsSection.title }}</h2>
              <p class="visit-activity-experience__intro block_title_style block_title_style--copy">{{ experienceHighlightsSection.intro }}</p>
            </div>
            <div class="visit-activity-experience__grid">
              {% for item in experienceHighlightsSection.items %}
              <article class="visit-activity-experience__card">
                <div class="visit-activity-experience__media">
                  <img src="{{ item.image }}" alt="{{ item.imageAlt }}" class="visit-activity-experience__image" />
                  <span class="visit-activity-experience__arrow" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none">
                      <path d="M5 19 19 5M8 5h11v11" />
                    </svg>
                  </span>
                </div>
                <h3>{{ item.title }}</h3>
                <button
                  type="button"
                  class="visit-activity-experience__trigger"
                  data-experience-trigger
                  aria-haspopup="dialog"
                  aria-controls="visitExperienceModal{{ loop.index0 }}"
                  aria-label="Mes informacio sobre {{ item.title }}"
                ></button>
              </article>

              <div class="visit-experience-modal" id="visitExperienceModal{{ loop.index0 }}" data-experience-modal hidden>
                <div class="visit-experience-modal__backdrop" data-experience-close="backdrop"></div>
                <div
                  class="visit-experience-modal__dialog"
                  role="dialog"
                  aria-modal="true"
                  aria-labelledby="visitExperienceModalTitle{{ loop.index0 }}"
                  aria-describedby="visitExperienceModalDescription{{ loop.index0 }}"
                >
                  <button
                    type="button"
                    class="visit-experience-modal__close"
                    data-experience-close="button"
                    aria-label="Tancar informacio"
                  >
                    <span aria-hidden="true">&times;</span>
                  </button>
                  <h2 id="visitExperienceModalTitle{{ loop.index0 }}">{{ item.title }}</h2>
                  <div id="visitExperienceModalDescription{{ loop.index0 }}" class="visit-experience-modal__text prose block_heavy_content_style">
                    {{ item.text | markdownify | safe }}
                  </div>
                  <p class="visit-experience-modal__prompt">Demana'ns mes informacio!</p>
                </div>
              </div>
              {% endfor %}
            </div>
          </div>
        </section>
        {% endif %}

        <section class="visit-activity-more unified-bg" aria-label="Altres activitats">
          <div class="visit-activity-more__inner">
            <div class="visit-activity-more__header">
              <h2 class="visit-activity-more__title block_title_style">O MIRA'T AQUESTES ALTRES VISITES</h2>
              <a href="/visits/" class="visit-activity-more__button">MIRAR TOTES ></a>
            </div>
            <div class="visit-activity-more__track">
              {% set shownActivities = 0 %}
              {% for activity in collections.visitActivities %}
              {% if activity.url != page.url and shownActivities < 3 %}
              <a href="{{ activity.url }}" class="visits-card-link visit-activity-more__link">
                <article class="visits-card visit-activity-more__card">
                  <img
                    src="{{ activity.data.cardImage }}"
                    alt="{{ activity.data.cardImageAlt }}"
                    class="visits-card__image"
                  />
                  <div class="visits-card__content">
                    <h3 class="visits-card__title">{{ activity.data.title }}</h3>
                    <p class="visits-card__text">{{ activity.data.cardDescription }}</p>
                    <div class="visits-card__meta">
                      <div class="visits-card__meta-item">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="lucide lucide-users"
                        >
                          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                          <circle cx="9" cy="7" r="4" />
                          <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                        <span>De {{ activity.data.personsMin }} a {{ activity.data.personsMax }} persones</span>
                      </div>
                      <div class="visits-card__meta-item">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="lucide lucide-clock"
                        >
                          <circle cx="12" cy="12" r="10" />
                          <polyline points="12 6 12 12 16 14" />
                        </svg>
                        <span>{{ activity.data.duration }}</span>
                      </div>
                    </div>
                  </div>
                </article>
              </a>
              {% set shownActivities = shownActivities + 1 %}
              {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>
      </div>

      {% include "footer.html" %}
    </div>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Inici",
            "item": {{ site.url | dump | safe }}
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Visites guiades",
            "item": {{ ('/visits/' | absoluteUrl(site.url)) | dump | safe }}
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ title | dump | safe }},
            "item": {{ (page.url | absoluteUrl(site.url)) | dump | safe }}
          }
        ]
      }
    </script>

    <script src="/assets/js/main.js"></script>
  </body>
</html>
