<!DOCTYPE html>
<html lang="{{ site.language }}">

  {% include "head.html" %}

  <body class="internal page-visit-activity{% if name %} page-{{ name }}{% endif %}">
    {% include "header.html" %}
    <div class="outer-wrap">
      <div class="content-wrap">
        <section class="visit-activity-hero hero-wrapper">
          <img
            src="{{ heroImage }}"
            alt="{{ heroImageAlt }}"
            class="hero-img visit-activity-hero__image"
          />

          <div class="hero-content-overlay visit-activity-hero__overlay">
            <div class="visit-activity-hero__content">
              <a href="/visits/" class="visit-activity-hero__back"
                >TORNAR A VISITES GUIADES</a
              >
              <h1 class="visit-activity-hero__title">{{ title }}</h1>

              {% if gallery and gallery.length %}
              <div class="visit-activity-hero__gallery">
                <a href="#visit-activity-gallery" class="visit-activity-hero__gallery-link">
                  {{ galleryButtonLabel or "VEURE GALERIA DE FOTOS" }}
                  <span aria-hidden="true">›</span>
                </a>
              </div>
              {% endif %}

              <div class="visit-activity-hero__actions">
                <p class="visit-activity-hero__reservation">{{ reservationPrompt }}</p>

                {% if whatsappLink %}
                <a
                  href="{{ whatsappLink }}"
                  class="visit-activity-hero__icon"
                  aria-label="WhatsApp"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M20 12a8 8 0 0 1-11.87 7l-4.13 1 1.09-4A8 8 0 1 1 20 12Z"
                    ></path>
                    <path d="M8.6 9.9c.2-.5.4-.5.6-.5h.5c.2 0 .4 0 .5.4l.7 1.7c.1.2.1.4 0 .5l-.4.5c-.1.1-.2.2-.1.4.2.4.6 1 1.2 1.6.7.6 1.4 1.1 1.8 1.2.2.1.3 0 .4-.1l.5-.6c.1-.1.3-.2.5-.1l1.6.8c.2.1.4.2.4.4v.5c0 .3-.1.5-.4.7-.3.2-.9.4-1.5.2-.7-.2-1.7-.7-2.9-1.8-1-.9-1.8-2-2.1-2.7-.3-.7-.1-1.4.1-1.7Z"
                    ></path>
                  </svg>
                </a>
                {% endif %}

                {% if emailAddress %}
                <a
                  href="mailto:{{ emailAddress }}"
                  class="visit-activity-hero__icon"
                  aria-label="Email"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                    <path d="m4 7 8 6 8-6"></path>
                  </svg>
                </a>
                {% endif %}

                {% if phoneNumber %}
                <a
                  href="tel:{{ phoneNumber | replace(' ', '') }}"
                  class="visit-activity-hero__icon"
                  aria-label="Telefon"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.1 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7l.5 3a2 2 0 0 1-.6 1.8L7.6 9.8a16 16 0 0 0 6.6 6.6l1.3-1.3a2 2 0 0 1 1.8-.6l3 .5A2 2 0 0 1 22 16.9Z"
                    ></path>
                  </svg>
                </a>
                {% endif %}
              </div>
            </div>

            <div class="visit-activity-hero__reserve-bar" aria-label="Condicions de reserva">
              <p class="visit-activity-hero__reserve-row">
                <span class="visit-activity-hero__reserve-label">RESERVA ARA I PAGA DESPRÉS</span>
                <span class="visit-activity-hero__reserve-text">Reserva plaça mantenint la flexibilitat</span>
              </p>
              <p class="visit-activity-hero__reserve-row">
                <span class="visit-activity-hero__reserve-label">POLÍTICA DE CANCEL·LACIÓ FLEXIBLE</span>
                <span class="visit-activity-hero__reserve-text">Fins a 48 hores abans de la visita</span>
              </p>
            </div>
          </div>
        </section>

        <section class="visit-activity-facts unified-bg">
          <div class="visit-activity-facts__inner">
            <div class="visit-activity-facts__item">
              <img
                src="/assets/images/gallery/visites/visites_people.png"
                alt=""
                class="visit-activity-facts__icon"
              />
              <div>
                <strong>De {{ personsMin }} a {{ personsMax }} persones</strong>
              </div>
            </div>
            <div class="visit-activity-facts__item">
              <img
                src="/assets/images/gallery/visites/visites_clock.png"
                alt=""
                class="visit-activity-facts__icon"
              />
              <div>
                <strong>{{ duration }}</strong>
              </div>
            </div>
            <div class="visit-activity-facts__item">
              <img
                src="/assets/images/gallery/visites/visites_money.png"
                alt=""
                class="visit-activity-facts__icon"
              />
              <div>
                <strong>A partir de {{ priceFrom }}</strong>
                <small>{{ priceNote }}</small>
              </div>
            </div>
            <div class="visit-activity-facts__item">
              <img
                src="/assets/images/gallery/visites/visites_walker.png"
                alt=""
                class="visit-activity-facts__icon"
              />
              <div>
                <strong>{{ difficulty }}</strong>
              </div>
            </div>
            <div class="visit-activity-facts__item">
              <img
                src="/assets/images/gallery/visites/visites_children.png"
                alt=""
                class="visit-activity-facts__icon"
              />
              <div>
                <strong>{{ kidFriendly }}</strong>
              </div>
            </div>
            <div class="visit-activity-facts__item">
              <img
                src="/assets/images/gallery/visites/visites_global.png"
                alt=""
                class="visit-activity-facts__icon"
              />
              <div>
                <strong>{{ languages }}</strong>
              </div>
            </div>
          </div>
        </section>

        <section class="visit-activity-body unified-bg">
          <div class="visit-activity-body__inner">
            <div class="visit-activity-body__main">
              <div class="visit-activity-section-title">DESCRIPCIO GENERAL</div>
              {% if overviewIntro %}
              <p class="visit-activity-body__intro">{{ overviewIntro }}</p>
              {% endif %}
              <div class="visit-activity-body__copy prose">{{ content | safe }}</div>

              <details class="visit-activity-accordion" open>
                <summary>SERVEIS INCLOSOS</summary>
                <div class="visit-activity-accordion__content prose">
                  {{ includedServices | markdownify | safe }}
                </div>
              </details>

              <details class="visit-activity-accordion">
                <summary>TROBADA I PUNT DE RECOLLIDA</summary>
                <div class="visit-activity-accordion__content prose">
                  {{ meetingPoint | markdownify | safe }}
                </div>
              </details>

              <details class="visit-activity-accordion">
                <summary>INFORMACIO ADDICIONAL</summary>
                <div class="visit-activity-accordion__content prose">
                  {{ additionalInfo | markdownify | safe }}
                </div>
              </details>
            </div>

            <aside class="visit-activity-sidebar">
              <section class="visit-activity-sidebar__section">
                <h2 class="visit-activity-sidebar__title">ITINERARI</h2>
                <div class="visit-activity-timeline">
                  {% for item in itinerary %}
                  <div class="visit-activity-timeline__item">
                    <div class="visit-activity-timeline__time">{{ item.time }}</div>
                    <div class="visit-activity-timeline__text">
                      <strong>{{ item.title }}</strong>
                      <p>{{ item.description }}</p>
                    </div>
                  </div>
                  {% endfor %}
                </div>
              </section>

              <section class="visit-activity-sidebar__section">
                <h2 class="visit-activity-sidebar__title">PREUS X PERSONA</h2>
                <div class="visit-activity-pricing">
                  {% for item in pricing %}
                  <div class="visit-activity-pricing__row">
                    <span>{{ item.group }}</span>
                    <strong>{{ item.price }}</strong>
                  </div>
                  {% endfor %}
                </div>
              </section>
            </aside>
          </div>
        </section>

        {% if experienceHighlightsSection and experienceHighlightsSection.items and experienceHighlightsSection.items.length %}
        <section class="visit-activity-experience">
          <div class="visit-activity-experience__inner">
            <div class="visit-activity-experience__header">
              <h2 class="visit-activity-experience__title">{{ experienceHighlightsSection.title }}</h2>
              <p class="visit-activity-experience__intro">{{ experienceHighlightsSection.intro }}</p>
            </div>
            <div class="visit-activity-experience__grid">
              {% for item in experienceHighlightsSection.items %}
              <article class="visit-activity-experience__card">
                <div class="visit-activity-experience__media">
                  <img src="{{ item.image }}" alt="{{ item.imageAlt }}" class="visit-activity-experience__image" />
                </div>
                <h3>{{ item.title }}</h3>
              </article>
              {% endfor %}
            </div>
          </div>
        </section>
        {% endif %}

        {% if gallery and gallery.length %}
        <section class="visit-activity-gallery unified-bg" id="visit-activity-gallery" aria-label="Galeria de fotos">
          <div class="visit-activity-gallery__inner">
            <div class="visit-activity-gallery__header title-nav-wrapper">
              <h2 class="visit-activity-gallery__title">GALERIA DE FOTOS</h2>
            </div>

            <div class="gallery-container visit-activity-gallery__wrap">
              <div class="gallery-scroll visit-activity-gallery__scroll" id="visitActivityGalleryScroll">
                {% for photo in gallery %}
                <div class="gallery-item visit-activity-gallery__item">
                  <img src="{{ photo.image }}" alt="{{ photo.alt }}" class="item-img visit-activity-gallery__image" />
                </div>
                {% endfor %}
              </div>
            </div>
          </div>
        </section>
        {% endif %}

        {% if reviewsSection and reviewsSection.reviews and reviewsSection.reviews.length %}
        <section class="visit-activity-reviews unified-bg" aria-label="Ressenyes de la visita">
          <div class="visit-activity-reviews__inner">
            <div class="visit-activity-reviews__header">
              <div class="visit-activity-reviews__heading">
                {% if reviewsSection.eyebrow %}
                <p class="visit-activity-reviews__eyebrow">{{ reviewsSection.eyebrow }}</p>
                {% endif %}
                {% if reviewsSection.title %}
                <h2 class="visit-activity-reviews__title">{{ reviewsSection.title }}</h2>
                {% endif %}
              </div>

              <div class="visit-activity-reviews__meta">
                <p class="visit-activity-reviews__rating-line">{{ reviewsSection.ratingLabel }}</p>
              </div>

              <div class="visit-activity-reviews__nav title-nav-wrapper">
                <button class="nav-arrow-inline left" id="visitActivityReviewsPrev" aria-label="Ressenya anterior">
                  <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </button>
                <button class="nav-arrow-inline right" id="visitActivityReviewsNext" aria-label="Ressenya següent">
                  <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </button>
              </div>
            </div>

            <div class="gallery-container visit-activity-reviews__carousel-wrap">
              <div class="gallery-scroll visit-activity-reviews__carousel" id="visitActivityReviewsScroll">
                {% for review in reviewsSection.reviews %}
                <article class="review-card visit-activity-reviews__card">
                  <img src="/assets/images/logo-google.png" alt="Google" class="google-logo" />
                  <div class="stars">★★★★★</div>
                  <p class="review-text">&ldquo;{{ review.quote }}&rdquo;</p>
                  <div class="reviewer-info">
                    <span class="reviewer-name">{{ review.author }}</span>
                    <span class="review-date">{{ review.date }}</span>
                    {% if review.avatar %}
                    <img src="{{ review.avatar }}" alt="{{ review.avatarAlt or review.author }}" class="reviewer-avatar" />
                    {% endif %}
                  </div>
                </article>
                {% endfor %}
              </div>
            </div>
          </div>
        </section>
        {% endif %}

        <section class="visit-activity-more unified-bg" aria-label="Altres activitats">
          <div class="visit-activity-more__inner">
            <div class="visit-activity-more__header">
              <h2 class="visit-activity-more__title">O MIRA'T AQUESTES ALTRES VISITES</h2>
              <a href="/visits/" class="visit-activity-more__button">MIRAR TOTES ></a>
            </div>
            <div class="visit-activity-more__track">
              {% for activity in collections.visitActivities %}
              {% if activity.url != page.url %}
              <a href="{{ activity.url }}" class="visits-card-link visit-activity-more__link">
                <article class="visits-card visit-activity-more__card">
                  <img
                    src="{{ activity.data.cardImage }}"
                    alt="{{ activity.data.cardImageAlt }}"
                    class="visits-card__image"
                  />
                  <div class="visits-card__content">
                    <h3 class="visits-card__title">{{ activity.data.title }}</h3>
                    <p class="visits-card__text">{{ activity.data.cardDescription }}</p>
                    <div class="visits-card__meta">
                      <div class="visits-card__meta-item">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="lucide lucide-users"
                        >
                          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                          <circle cx="9" cy="7" r="4" />
                          <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                        <span>De {{ activity.data.personsMin }} a {{ activity.data.personsMax }} persones</span>
                      </div>
                      <div class="visits-card__meta-item">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="lucide lucide-clock"
                        >
                          <circle cx="12" cy="12" r="10" />
                          <polyline points="12 6 12 12 16 14" />
                        </svg>
                        <span>{{ activity.data.duration }}</span>
                      </div>
                    </div>
                  </div>
                </article>
              </a>
              {% endif %}
              {% endfor %}
            </div>
          </div>
        </section>
      </div>

      {% include "footer.html" %}
    </div>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Inici",
            "item": {{ site.url | dump | safe }}
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Visites guiades",
            "item": {{ ('/visits/' | absoluteUrl(site.url)) | dump | safe }}
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ title | dump | safe }},
            "item": {{ (page.url | absoluteUrl(site.url)) | dump | safe }}
          }
        ]
      }
    </script>

    <script src="/assets/js/main.js"></script>
  </body>
</html>
