---
layout: base
---

{% set pageContent = actualitat.page %}
{% set articleDescription = seoDescription or description or title %}

<article class="actualitat-post">
  <div class="container actualitat-post__inner">
    <a class="actualitat-post__back" href="/blog/">← TORNAR</a>

    <header class="actualitat-post__header">
      <time class="actualitat-post__date" datetime="{{ page.date | htmlDateString }}">
        {% if displayDate %}{{ displayDate }}{% else %}{{ page.date | readableDate }}{% endif %}
      </time>
      <h1 class="actualitat-post__title">{{ title }}</h1>
      {% if description %}
      <p class="actualitat-post__subtitle">{{ description }}</p>
      {% endif %}

      <div class="actualitat-post__meta" aria-label="Informació de l'article">
        <p>
          <strong>Temps de lectura</strong>
          {% if readingTimeValue %}{{ readingTimeValue }}{% else %}{{ content | readingTime }} minuts{% endif %}
        </p>
        <p>
          <strong>Etiquetes</strong>
          {% for tag in tags %}
            {% if tag != "posts" %}{{ tag }}{% if not loop.last %}, {% endif %}{% endif %}
          {% endfor %}
        </p>
      </div>
    </header>
  </div>

  {% if image %}
  <figure class="actualitat-post__hero">
    <img src="{{ image }}" alt="{% if imageAlt %}{{ imageAlt }}{% else %}{{ title }}{% endif %}" />
  </figure>
  {% endif %}

  <div class="container actualitat-post__body">
    <div class="actualitat-post__content">
      {{ content | safe }}
    </div>

    {% if quote %}
    <aside class="actualitat-post__quote" aria-label="Cita destacada">
      <blockquote>“{{ quote }}”</blockquote>
      {% if quoteAuthor %}
      <p>— {{ quoteAuthor }}</p>
      {% endif %}
    </aside>
    {% endif %}
  </div>

  <nav class="container actualitat-post__nav" aria-label="Articles relacionats">
    <a href="/blog/">← ANTERIOR ARTICLE</a>
    <a href="/blog/">SEGÜENT ARTICLE →</a>
  </nav>
</article>

<section class="actualitat-newsletter" aria-labelledby="actualitat-post-newsletter-title">
  <div class="container actualitat-newsletter-inner">
    <div class="actualitat-newsletter-copy">
      <h2 id="actualitat-post-newsletter-title">{{ pageContent.newsletter.title }}</h2>
      <p>{{ pageContent.newsletter.text }}</p>
    </div>
    <form class="actualitat-newsletter-form">
      <label class="sr-only" for="actualitat-post-newsletter-email">{{ pageContent.newsletter.inputLabel }}</label>
      <input id="actualitat-post-newsletter-email" type="email" />
      <button type="submit">{{ pageContent.newsletter.buttonLabel }}</button>
    </form>
  </div>
</section>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ (seoTitle or title) | dump | safe }},
    "description": {{ articleDescription | dump | safe }},
    "datePublished": {{ page.date.toISOString() | dump | safe }},
    "dateModified": {{ page.date.toISOString() | dump | safe }},
    "mainEntityOfPage": {{ (page.url | absoluteUrl(site.url)) | dump | safe }},
    "author": {
      "@type": "Organization",
      "name": {{ site.name | dump | safe }}
    },
    "publisher": {
      "@type": "Organization",
      "name": {{ site.name | dump | safe }},
      "logo": {
        "@type": "ImageObject",
        "url": {{ ('/assets/images/logo.png' | absoluteUrl(site.url)) | dump | safe }}
      }
    }{% if image %},
    "image": [{{ (image | absoluteUrl(site.url)) | dump | safe }}]{% endif %}
  }
</script>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inici",
        "item": {{ site.url | dump | safe }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Actualitat",
        "item": {{ ('/blog/' | absoluteUrl(site.url)) | dump | safe }}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ title | dump | safe }},
        "item": {{ (page.url | absoluteUrl(site.url)) | dump | safe }}
      }
    ]
  }
</script>
