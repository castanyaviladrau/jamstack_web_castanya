<!DOCTYPE html>
<html lang="{{ site.language }}">

  {% include "head.html" %}

  {% set recipes = collections.recipes %}
  {% set currentIndex = -1 %}
  {% for item in recipes %}
    {% if item.url == page.url %}
      {% set currentIndex = loop.index0 %}
    {% endif %}
  {% endfor %}
  {% set previousRecipe = recipes[currentIndex - 1] if currentIndex > 0 else null %}
  {% set nextRecipe = recipes[currentIndex + 1] if currentIndex > -1 and currentIndex < (recipes | length - 1) else null %}
  {% set relatedProductsSectionData = relatedProductsSection or {} %}
  {% set relatedProductKeys = relatedProductsSectionData.products or [] %}

  <body class="internal{% if name %} page-{{ name }}{% endif %}">
    {% include "header.html" %}
    <div class="outer-wrap">
      <div class="content-wrap unified-bg">
        <section class="recipe-detail">
          <div class="recipe-detail__inner">
            <a href="/gastronomic/receptes/" class="recipe-detail__back">&larr; Tornar</a>

            <div class="recipe-detail__header">
              <div class="recipe-detail__media-wrap">
                <img
                  src="{{ image }}"
                  alt="{{ imageAlt }}"
                  class="recipe-detail__image"
                />
              </div>

              <div class="recipe-detail__summary">
                <h1 class="recipe-detail__title">{{ title }}</h1>
                <p class="recipe-detail__author">Per {{ author }}, {{ origin }}</p>
                <p class="recipe-detail__description">{{ summary }}</p>

                <div class="recipe-detail__meta">
                  <span class="recipe-detail__meta-item"
                    ><svg viewBox="0 0 24 24" aria-hidden="true">
                      <circle cx="12" cy="12" r="8"></circle>
                      <path d="M12 7v5l3 2"></path></svg
                    >{{ time }}</span
                  >
                  <span class="recipe-detail__meta-item"
                    ><img
                      src="/assets/images/gallery/espai-gastronomic/espai_grade.png"
                      alt=""
                      aria-hidden="true"
                    />{{ difficulty }}</span
                  >
                </div>

                {% if pdfEnabled %}
                <a
                  href="/api/recipe-pdf?slug={{ page.fileSlug }}"
                  class="btn-olive recipe-detail__download"
                >{{ downloadPdfLabel }}</a>
                {% endif %}
              </div>
            </div>

            {% if content %}
            <div class="recipe-detail__intro prose">{{ content | safe }}</div>
            {% endif %}

            <div class="recipe-detail__grid">
              <div class="recipe-detail__main">
                {% for step in steps %}
                <section class="recipe-detail__step">
                  <h2 class="recipe-detail__step-title">{{ step.title }}</h2>
                  <p class="recipe-detail__step-text">{{ step.text }}</p>
                </section>
                {% endfor %}
              </div>

              <aside class="recipe-detail__sidebar">
                <section class="recipe-detail__aside-section">
                  <h2 class="recipe-detail__aside-title block_title_style">{{ ingredientsLabel }}</h2>
                  <ul class="recipe-detail__ingredients">
                    {% for ingredient in ingredients %}
                    <li>{{ ingredient }}</li>
                    {% endfor %}
                  </ul>
                </section>

                <section class="recipe-detail__secret">
                  <h2 class="recipe-detail__aside-title block_title_style">{{ secretTitle }}</h2>
                  <p class="recipe-detail__secret-quote">&ldquo;{{ secretQuote }}&rdquo;</p>
                </section>
              </aside>
            </div>

            <nav class="recipe-detail__pagination" aria-label="Navegacio entre receptes">
              {% if previousRecipe %}
              <a href="{{ previousRecipe.url }}" class="recipe-detail__pagination-link">&larr; Anterior recepta</a>
              {% else %}
              <span class="recipe-detail__pagination-link recipe-detail__pagination-link--disabled">&larr; Anterior recepta</span>
              {% endif %}

              {% if nextRecipe %}
              <a href="{{ nextRecipe.url }}" class="recipe-detail__pagination-link">Següent recepta &rarr;</a>
              {% else %}
              <span class="recipe-detail__pagination-link recipe-detail__pagination-link--disabled">Següent recepta &rarr;</span>
              {% endif %}
            </nav>

            {% if relatedProductKeys | length %}
            <section class="recipe-detail__related-products" aria-labelledby="recipe-related-products-title">
              <div class="recipe-detail__related-products-header">
                <h2 id="recipe-related-products-title" class="recipe-detail__related-products-title block_title_style">
                  {{ relatedProductsSectionData.title }}
                </h2>
                <p class="recipe-detail__related-products-intro block_title_content">{{ relatedProductsSectionData.intro }}</p>
              </div>

              <div class="recipe-detail__related-products-grid">
                {% for productKey in relatedProductKeys %}
                  {% set product = recipeProducts[productKey] %}
                  {% if product %}
                  <a href="{{ product.href }}" class="recipe-detail__related-product-card">
                    <img
                      src="{{ product.image }}"
                      alt="{{ product.imageAlt }}"
                      class="recipe-detail__related-product-image"
                    />
                    <h3 class="recipe-detail__related-product-title">{{ product.title }}</h3>
                    <p class="recipe-detail__related-product-subtitle">{{ product.subtitle }}</p>
                    <p class="recipe-detail__related-product-price">{{ product.price }}</p>
                  </a>
                  {% endif %}
                {% endfor %}
              </div>
            </section>
            {% endif %}
          </div>
        </section>
      </div>
      {% include "footer.html" %}
    </div>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": {{ title | dump | safe }},
        "description": {{ (seoDescription or summary or description or title) | dump | safe }},
        "image": [{{ (seoImage or image or site.defaultOgImage) | absoluteUrl(site.url) | dump | safe }}],
        "author": {
          "@type": "Person",
          "name": {{ (author or site.name) | dump | safe }}
        },
        "recipeIngredient": {{ (ingredients or []) | dump | safe }},
        "recipeInstructions": [
          {% for step in steps %}
          {
            "@type": "HowToStep",
            "name": {{ step.title | dump | safe }},
            "text": {{ step.text | dump | safe }}
          }{% if not loop.last %},{% endif %}
          {% endfor %}
        ]
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Inici",
            "item": {{ site.url | dump | safe }}
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Receptes",
            "item": {{ ('/gastronomic/receptes/' | absoluteUrl(site.url)) | dump | safe }}
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ title | dump | safe }},
            "item": {{ (page.url | absoluteUrl(site.url)) | dump | safe }}
          }
        ]
      }
    </script>
    <script src="/assets/js/main.js"></script>
  </body>
</html>
