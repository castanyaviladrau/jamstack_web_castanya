---
layout: base
footerVariant: projecte-newsletter
---

{% set currentUrl = page.url %}
{% set relatedCollection = collections.products | default([]) | reverse %}
{% set relatedFallback = relatedProducts.list | default([]) %}
{% set defaultFormat = formats[0] if formats and formats.length else null %}
{% set defaultSku = defaultFormat.sku if defaultFormat and defaultFormat.sku else sku %}
{% set defaultPrice = defaultFormat.price if defaultFormat and defaultFormat.price else price %}
{% set priceText = priceLabel or price %}

<section class="product-detail">
  <div class="product-detail__inner">
    <a href="/shop/products/" class="product-detail__back">&larr; TORNAR</a>

    <div class="product-detail__grid">
      <div class="product-detail__media">
        <img
          src="{{ image }}"
          alt="{{ title }}"
          class="product-detail__main-image"
        />

        {% if gallery and gallery.length %}
          <div class="product-detail__thumbs" aria-label="Galeria del producte">
            {% for item in gallery %}
              <img
                src="{{ item.image }}"
                alt="{{ title }} vista {{ loop.index }}"
                class="product-detail__thumb"
              />
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <aside class="product-detail__aside">
        <p class="product-detail__brand">CASTANYA DE<br />VILADRAU TORRADA</p>
        <h1 class="product-detail__title">{{ title }}</h1>
        <p class="product-detail__tagline">{{ tagline }}</p>

        <div class="product-detail__purchase">
          <label class="product-detail__format-label" for="product-format">{{ formatLabel }}</label>
          <select id="product-format" class="product-detail__format-select">
            {% for option in formats %}
              {% set optionLabel = option.label if option.label else option %}
              {% set optionSku = option.sku if option.sku else sku %}
              {% set optionPrice = option.price if option.price else price %}
              <option value="{{ optionLabel }}" data-sku="{{ optionSku }}" data-price="{{ optionPrice }}">{{ optionLabel }}</option>
            {% endfor %}
          </select>

          <button
            type="button"
            class="product-detail__cta"
            data-add-to-cart
            data-product-slug="{{ page.fileSlug }}"
            data-product-name="{{ title }}"
            data-product-image="{{ image }}"
            data-product-sku="{{ defaultSku }}"
            data-product-price="{{ defaultPrice }}"
            data-product-currency="{{ currency or 'EUR' }}"
          >
            {{ ctaLabel }}
          </button>
          <p class="product-detail__cta-feedback" data-add-to-cart-feedback hidden></p>
        </div>

        <div class="product-detail__info-list">
          <p class="product-detail__shipping">{{ shippingNote }}</p>

          {% if highlights and highlights.length %}
            {% for item in highlights %}
              <p class="product-detail__info-item">{{ item.text }}</p>
            {% endfor %}
          {% endif %}
        </div>

        <div class="product-detail__ingredients">
          <h2 class="product-detail__aside-title">{{ ingredientsLabel }}</h2>
          <p class="product-detail__ingredients-text">{{ ingredients }}</p>
        </div>

        <div class="product-detail__notes">
          <p class="product-detail__price" data-product-price-display>{{ priceText }}</p>
          <p class="product-detail__availability">{{ availability }}</p>

          {% if detailNotes and detailNotes.length %}
            {% for item in detailNotes %}
              <p class="product-detail__note">{{ item.text }}</p>
            {% endfor %}
          {% endif %}
        </div>
      </aside>
    </div>

    <div class="product-detail__content-grid">
      <div class="product-detail__content">
        <h2 class="product-detail__content-title">{{ detailLabel }}</h2>
        <div class="product-detail__body">{{ content | safe }}</div>
      </div>
    </div>

    <div class="product-detail__pager">
      <a href="/shop/products/" class="product-detail__pager-link">&larr; ANTERIOR PRODUCTE</a>
      <a href="/shop/products/" class="product-detail__pager-link">SEGUENT PRODUCTE &rarr;</a>
    </div>
  </div>
</section>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ title | dump | safe }},
    "description": {{ (seoDescription or description or tagline or ingredients) | dump | safe }},
    "image": [{{ (seoImage or image or site.defaultOgImage) | absoluteUrl(site.url) | dump | safe }}],
    "brand": {
      "@type": "Brand",
      "name": {{ site.name | dump | safe }}
    },
    "url": {{ (page.url | absoluteUrl(site.url)) | dump | safe }},
    "availability": {{ availability | dump | safe }}
  }
</script>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inici",
        "item": {{ site.url | dump | safe }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Botiga",
        "item": {{ ('/shop/products/' | absoluteUrl(site.url)) | dump | safe }}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ title | dump | safe }},
        "item": {{ (page.url | absoluteUrl(site.url)) | dump | safe }}
      }
    ]
  }
</script>

<section class="product-detail__related" aria-labelledby="product-related-title">
  <div class="product-detail__related-inner">
    <h2 id="product-related-title" class="product-detail__related-title">
      ALTRES PRODUCTES QUE ET PODRIEN AGRADAR
    </h2>

    <div class="product-detail__related-grid">
      {% if relatedCollection and relatedCollection.length > 1 %}
        {% for product in relatedCollection %}
          {% if product.url != currentUrl and loop.index0 < 8 %}
            <a href="{{ product.url }}" class="product-detail__related-card">
              <img
                src="{{ product.data.image }}"
                alt="{{ product.data.title }}"
                class="product-detail__related-image"
              />
              <h3 class="product-detail__related-name">{{ product.data.title }}</h3>
              <p class="product-detail__related-meta">{{ product.data.availability }}</p>
              <p class="product-detail__related-price">{{ product.data.price }}</p>
            </a>
          {% endif %}
        {% endfor %}
      {% else %}
        {% for product in relatedFallback %}
          {% if loop.index0 < 8 %}
            <a href="{{ product.url }}" class="product-detail__related-card">
              <img
                src="{{ product.image }}"
                alt="{{ product.title }}"
                class="product-detail__related-image"
              />
              <h3 class="product-detail__related-name">{{ product.title }}</h3>
              <p class="product-detail__related-meta">{{ product.availability }}</p>
              <p class="product-detail__related-price">{{ product.price }}</p>
            </a>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>
