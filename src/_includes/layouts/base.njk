<!DOCTYPE html>
<html lang="{{ site.language }}">

  {% include "head.html" %}

  <body class="{% if page.url == '/' %}home{% else %}internal{% endif %}{% if name %} page-{{ name }}{% endif %}">


    {% include "header.html" %}
    <div class="outer-wrap">

      <div class="content-wrap">
      {{ content | safe }}
      </div>

      {% include "footer.html" %}

      <section
        class="cookie-banner"
        id="cookieBanner"
        aria-label="Avis de cookies"
        hidden
      >
        <div class="cookie-banner__inner">
          <div class="cookie-banner__copy">
            <p class="cookie-banner__eyebrow">Cookies</p>
            <p class="cookie-banner__text">
              Utilitzem cookies propies i de tercers per millorar la navegacio,
              analitzar l'us del web i oferir una experiencia mes rellevant.
              Pots acceptar-les, rebutjar-les o consultar-ne el detall a la
              <a href="/politica-de-cookies/">politica de cookies</a>.
            </p>
          </div>
          <div class="cookie-banner__actions">
            <button
              type="button"
              class="cookie-banner__button cookie-banner__button--secondary"
              data-cookie-action="reject"
            >
              Rebutjar
            </button>
            <button
              type="button"
              class="cookie-banner__button cookie-banner__button--primary"
              data-cookie-action="accept"
            >
              Acceptar
            </button>
          </div>
        </div>
      </section>

    </div>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": {{ site.name | dump | safe }},
        "url": {{ site.url | dump | safe }},
        "logo": {{ ('/assets/images/logo.png' | absoluteUrl(site.url)) | dump | safe }},
        "email": {{ site.business.email | dump | safe }},
        "telephone": {{ site.business.phone | dump | safe }},
        "address": {
          "@type": "PostalAddress",
          "streetAddress": {{ site.business.address.streetAddress | dump | safe }},
          "addressLocality": {{ site.business.address.addressLocality | dump | safe }},
          "postalCode": {{ site.business.address.postalCode | dump | safe }},
          "addressRegion": {{ site.business.address.addressRegion | dump | safe }},
          "addressCountry": {{ site.business.address.addressCountry | dump | safe }}
        }{% if site.social.instagram or site.social.whatsapp %},
        "sameAs": [
          {% if site.social.instagram %}{{ site.social.instagram | dump | safe }}{% if site.social.whatsapp %},{% endif %}{% endif %}
          {% if site.social.whatsapp %}{{ site.social.whatsapp | dump | safe }}{% endif %}
        ]{% endif %}
      }
    </script>
    <script src="/assets/js/main.js"></script>
  </body>
</html>
